# Database Configuration
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/energy_community

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# SMTP Configuration (optional — for email alert notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@energyhub.com
MAIL_FROM_NAME=EnergyHub
MAIL_TLS=True
MAIL_SSL=False
